{
  "name": "cookrew-mono",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @cookrew/bff dev & pnpm --filter @cookrew/web dev",
    "dev:web": "pnpm --filter @cookrew/web dev",
    "dev:bff": "pnpm --filter @cookrew/bff dev",
    "build": "pnpm --filter @cookrew/shared typecheck && pnpm --filter @cookrew/web build && pnpm --filter @cookrew/bff typecheck",
    "build:web": "pnpm --filter @cookrew/web build",
    "build:bff": "pnpm --filter @cookrew/bff typecheck",
    "lint": "pnpm --filter @cookrew/web lint",
    "test:e2e": "playwright test",
    "test:e2e:trace": "PW_TRACE=on PW_SERVER_LOGS=1 playwright test --trace on",
    "typecheck": "pnpm -r typecheck",
    "ab:open": "agent-browser open http://127.0.0.1:3210",
    "ab:debug": "agent-browser batch --bail \"open http://127.0.0.1:3210\" \"snapshot -i -c\" \"console\" \"errors\" \"network requests\"",
    "ab:dashboard": "agent-browser dashboard start --port 4848"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2"
  }
}
