FROM oven/bun:1.3-alpine
WORKDIR /app

# Copy shared package (consumed as raw TS source via tsconfig paths)
COPY packages/shared/ packages/shared/

# Install BFF deps without workspace resolution
COPY packages/bff/ packages/bff/
WORKDIR /app/packages/bff
RUN bun add hono
WORKDIR /app

RUN mkdir -p /app/packages/bff/data
EXPOSE 3001
CMD ["bun", "run", "packages/bff/src/index.ts"]
